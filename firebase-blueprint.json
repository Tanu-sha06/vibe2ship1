{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and clearance level",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Auth"
        },
        "name": {
          "type": "string",
          "description": "User full name"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "role": {
          "type": "string",
          "enum": ["citizen", "official"],
          "description": "User role"
        },
        "points": {
          "type": "number",
          "description": "Activity or score points"
        },
        "createdAt": {
          "type": "string",
          "description": "Creation timestamp in ISO format"
        }
      },
      "required": ["uid", "name", "email", "role", "points"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
