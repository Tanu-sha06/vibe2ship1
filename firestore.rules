rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'points'])
        && data.uid is string
        && data.uid.size() > 0
        && data.uid.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 150
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 200
        && data.role is string
        && (data.role == 'citizen' || data.role == 'official')
        && (data.points is int || data.points is float)
        && (!('createdAt' in data) || data.createdAt is string);
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }
  }
}
